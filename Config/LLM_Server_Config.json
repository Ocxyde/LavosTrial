{
    "_comment": "Code.Lavos - Local LLM Server Configuration for Unity C#",
    "_version": "1.0.0",
    "_license": "GPL-3.0",
    "llm": {
        "enabled": true,
        "provider": "ollama",
        "server": {
            "baseUrl": "http://localhost:8080",
            "generateEndpoint": "/api/generate",
            "chatEndpoint": "/api/chat",
            "modelsEndpoint": "/api/tags",
            "timeout": 120000,
            "maxRetries": 3
        },
        "authentication": {
            "required": false,
            "type": "none",
            "apiKey": ""
        },
        "model": {
            "name": "llama3.2:3b",
            "contextWindow": 4096,
            "maxTokens": 2048
        },
        "generation": {
            "temperature": 0.7,
            "topP": 0.9,
            "topK": 40,
            "repeatPenalty": 1.1,
            "seed": -1
        },
        "systemPrompt": "You are a helpful assistant for Code.Lavos Unity game project. Provide concise, accurate answers about maze generation, C# coding, and Unity development."
    },
    "providers": {
        "ollama": {
            "baseUrl": "http://localhost:8080",
            "generateEndpoint": "/api/generate",
            "chatEndpoint": "/api/chat",
            "requestFormat": {
                "model": "{model}",
                "prompt": "{prompt}",
                "stream": false,
                "options": {
                    "temperature": "{temperature}",
                    "top_p": "{topP}",
                    "top_k": "{topK}",
                    "repeat_penalty": "{repeatPenalty}",
                    "num_predict": "{maxTokens}"
                }
            }
        },
        "lmstudio": {
            "baseUrl": "http://localhost:8080",
            "generateEndpoint": "/v1/completions",
            "chatEndpoint": "/v1/chat/completions",
            "requestFormat": {
                "model": "{model}",
                "messages": [
                    {
                        "role": "system",
                        "content": "{systemPrompt}"
                    },
                    {
                        "role": "user",
                        "content": "{prompt}"
                    }
                ],
                "temperature": "{temperature}",
                "max_tokens": "{maxTokens}"
            }
        },
        "koboldcpp": {
            "baseUrl": "http://localhost:5001",
            "generateEndpoint": "/api/v1/generate",
            "requestFormat": {
                "prompt": "{prompt}",
                "max_context_length": "{contextWindow}",
                "max_length": "{maxTokens}",
                "temperature": "{temperature}",
                "top_p": "{topP}",
                "rep_pen": "{repeatPenalty}"
            }
        },
        "text-generation-webui": {
            "baseUrl": "http://localhost:5000",
            "generateEndpoint": "/api/v1/generate",
            "chatEndpoint": "/api/v1/chat/completions",
            "requestFormat": {
                "prompt": "{prompt}",
                "max_new_tokens": "{maxTokens}",
                "temperature": "{temperature}",
                "top_p": "{topP}",
                "repetition_penalty": "{repeatPenalty}"
            }
        }
    }
}
