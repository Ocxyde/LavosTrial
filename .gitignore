# Unity generated
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
*.pidb.meta
*.pdb.meta

# Visual Studio
.vs/
*.suo
*.csproj
*.sln
*.userprefs

# Backup & temp files (use Git for version history!)
*.backup
*.backup.meta
*.bak
*.bak.meta
*.tmp

# Backup folder numbered files (e.g., Script_00001.cs)
Backup/**/*_00*.cs
Backup/**/*_00*.cs.meta
**/Backup_*/**/*_00*.cs
**/Backup_*/**/*_00*.cs.meta

# ZIP archives in backup folders
Backup/**/*.zip
Backup/**/*.zip.meta
**/Backup_*/**/*.zip
**/Backup_*/**/*.zip.meta
Assets/**/*.zip
Assets/**/*.zip.meta

# Prevent duplicate TODO.md outside Assets/Docs
Docs/TODO.md
Docs/TODO.md.meta

# Recovery & temp Unity folders
Assets/Temp/
Assets/Temp.meta
Assets/_Recovery/
Assets/_Recovery.meta

# OS
.DS_Store
Thumbs.db

# Added by git-cleanup-repo.ps1
*.7z

# Added by git-cleanup-repo.ps1
Backup_Solution/

# Added by git-cleanup-repo.ps1
Backup_Deprecated_*/

# Added by git-cleanup-repo.ps1
maze_v0-*/

# Added by git-cleanup-repo.ps1
Builds_*/

# Added by git-cleanup-repo.ps1
*.unitypackage

# PowerShell scripts and batch files (user-managed)
*.ps1
*.bat

# ZIP archives (root and all subfolders)
*.zip
*.zip.meta

# Backup folders (all variants)
Backup/
Backup_*/
Backup*/
**/Backup/**
**/Backup_*/**

# Maze version folders (all variants)
maze_v0-*/
**/maze_v0-*/**

# Temp diff & file storage (user-managed)
diff_tmp/
files/

# Markdown files (track all .md in root, ignore README.md)
!*.md
README.md
