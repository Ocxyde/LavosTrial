# Unity specific excludes
*.meta (optional - uncomment if you don't want to track meta files)
ProjectSettings/*.asset
ProjectSettings/*.unity
ProjectSettings/*.prefab

# Keep these project settings
!ProjectSettings/ProjectSettings.asset
!ProjectSettings/EditorBuildSettings.asset
!ProjectSettings/InputManager.asset
!ProjectSettings/TagManager.asset
!ProjectSettings/TimeManager.asset
!ProjectSettings/Physics2DSettings.asset
!ProjectSettings/NavMeshAreas.asset
!ProjectSettings/QualitySettings.asset
!ProjectSettings/GraphicsSettings.asset
!ProjectSettings/AudioManager.asset
!ProjectSettings/ProjectVersion.txt

# Exclude large asset bundles unless needed
*.unitypackage
*.zip
*.rar
*.7z

# Exclude video and audio files (optional)
# *.mp4
# *.mov
# *.avi
# *.mp3
# *.wav

# Exclude texture source files (optional)
# *.psd
# *.ai
# *.tif
# *.tiff

# Unity 6 specific
*.unityhub
*.unity-6
